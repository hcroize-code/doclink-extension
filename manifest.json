{
  "manifest_version": 3,
  "name": "DocLink",
  "version": "1.0.0",
  "description": "Detect Google Docs, Sheets & Slides links shared via Gmail. Organize them into folders without leaving Chrome.",
  "homepage_url": "https://github.com/hcroize-code/doclink-extension",

  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "779013325294-81h2mgvd61borau1bfrsviv922cqee8j.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DocLink",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
